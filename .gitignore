# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Dados de entrada (arquivos do cliente — não versionados)
CVC_IAM_ANALYTICS/ENTRADA/**/*.csv
CVC_IAM_ANALYTICS/ENTRADA/**/*.CSV
CVC_IAM_ANALYTICS/ENTRADA/**/*.xlsx
CVC_IAM_ANALYTICS/ENTRADA/**/*.xls

# Saídas geradas
CVC_IAM_ANALYTICS/DADOS/SAIDAS/**/*.csv
CVC_IAM_ANALYTICS/DADOS/SAIDAS/**/*.xlsx
CVC_IAM_ANALYTICS/DADOS/SAIDAS/**/*.pdf

# Banco de dados
CVC_IAM_ANALYTICS/DADOS/BANCO/*.db
CVC_IAM_ANALYTICS/DADOS/BANCO/*.sqlite

# Parquet gerado
CVC_IAM_ANALYTICS/DADOS/PARQUET/**/*.parquet

# Arquivos processados e de erro
CVC_IAM_ANALYTICS/DADOS/PROCESSADOS/
CVC_IAM_ANALYTICS/DADOS/ERROS/

# Logs
CVC_IAM_ANALYTICS/DADOS/LOGS/

# Pasta de arquivos de origem (dados brutos do cliente)
Arquivos_origem/

# IDEs
.vscode/
.idea/
*.code-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Executáveis gerados
CVC_IAM_ANALYTICS/EXECUTAVEIS/*.exe

# Artefatos de build PyInstaller
deploy/_build/

# Configurações locais do Claude
.claude/

# Power BI — arquivos locais e cache (não versionados)
**/.pbi/localSettings.json
**/.pbi/cache.abf
