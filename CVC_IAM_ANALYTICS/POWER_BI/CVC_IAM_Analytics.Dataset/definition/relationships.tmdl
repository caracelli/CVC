relationship d_systur
	crossFilteringBehavior: bothDirections
	fromColumn: Divergencias.usuario
	toColumn: SYSTUR.usuario

relationship d_rh_ativos
	crossFilteringBehavior: bothDirections
	fromColumn: Divergencias.matricula
	toColumn: RH_Ativos.matricula

relationship rh_ativos_matriz
	fromColumn: RH_Ativos.cargo_codigo
	toColumn: Matriz_Organizacional.cargo_codigo

