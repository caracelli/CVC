<?xml version="1.0" encoding="UTF-8"?>
<configuracao>
    <versao>1.0.0</versao>
    <cliente>CVC</cliente>
    <projeto>IAM Analytics</projeto>

    <caminhos>
        <raiz>.</raiz>
        <entrada>ENTRADA</entrada>
        <saidas>DADOS/SAIDAS</saidas>
        <banco_dados>DADOS/BANCO/iam_analytics.db</banco_dados>
        <parquet>DADOS/PARQUET</parquet>
        <processados>DADOS/PROCESSADOS</processados>
        <erros>DADOS/ERROS</erros>
        <logs>DADOS/LOGS</logs>
    </caminhos>

    <rh>
        <ativos>
            <caminho>ENTRADA/RH/ATIVOS</caminho>
            <colunas>
                <matricula>MATRICULA</matricula>
                <nome>NOME</nome>
                <cpf>CPF</cpf>
                <cargo_codigo>CARGO_CODIGO</cargo_codigo>
                <cargo_descricao>CARGO_DESCRICAO</cargo_descricao>
                <departamento>DEPARTAMENTO</departamento>
                <centro_custo>CENTRO_CUSTO</centro_custo>
                <data_admissao>DATA_ADMISSAO</data_admissao>
                <email>EMAIL</email>
                <situacao>SITUACAO</situacao>
            </colunas>
        </ativos>
        <desligados>
            <caminho>ENTRADA/RH/DESLIGADOS</caminho>
            <colunas>
                <matricula>MATRICULA</matricula>
                <nome>NOME</nome>
                <cpf>CPF</cpf>
                <data_desligamento>DATA_DESLIGAMENTO</data_desligamento>
                <motivo>MOTIVO</motivo>
            </colunas>
        </desligados>
    </rh>

    <sistemas>
        <sistema id="SIGOT">
            <nome>SIGOT</nome>
            <descricao>Sistema de Gestão de Operações e Turismo</descricao>
            <caminho_entrada>ENTRADA/SISTEMAS/SIGOT</caminho_entrada>
            <caminho_parquet>DADOS/PARQUET/ACESSOS/SIGOT</caminho_parquet>
            <colunas>
                <usuario>USUARIO</usuario>
                <nome>NOME</nome>
                <perfil>PERFIL</perfil>
                <situacao>SITUACAO</situacao>
                <data_criacao>DATA_CRIACAO</data_criacao>
                <ultimo_acesso>ULTIMO_ACESSO</ultimo_acesso>
            </colunas>
        </sistema>

        <sistema id="SICA_RA">
            <nome>SICA_RA</nome>
            <descricao>Sistema de Controle de Acesso - Rede Agência</descricao>
            <caminho_entrada>ENTRADA/SISTEMAS/SICA_RA</caminho_entrada>
            <caminho_parquet>DADOS/PARQUET/ACESSOS/SICA_RA</caminho_parquet>
            <colunas>
                <usuario>USUARIO</usuario>
                <nome>NOME</nome>
                <perfil>PERFIL</perfil>
                <situacao>SITUACAO</situacao>
                <data_criacao>DATA_CRIACAO</data_criacao>
                <ultimo_acesso>ULTIMO_ACESSO</ultimo_acesso>
            </colunas>
        </sistema>

        <sistema id="SICA_ESFERA">
            <nome>SICA_ESFERA</nome>
            <descricao>Sistema de Controle de Acesso - Esfera</descricao>
            <caminho_entrada>ENTRADA/SISTEMAS/SICA_ESFERA</caminho_entrada>
            <caminho_parquet>DADOS/PARQUET/ACESSOS/SICA_ESFERA</caminho_parquet>
            <colunas>
                <usuario>USUARIO</usuario>
                <nome>NOME</nome>
                <perfil>PERFIL</perfil>
                <situacao>SITUACAO</situacao>
                <data_criacao>DATA_CRIACAO</data_criacao>
                <ultimo_acesso>ULTIMO_ACESSO</ultimo_acesso>
            </colunas>
        </sistema>

        <sistema id="SYSTUR">
            <nome>SYSTUR</nome>
            <descricao>Sistema de Turismo</descricao>
            <caminho_entrada>ENTRADA/SISTEMAS/SYSTUR</caminho_entrada>
            <caminho_parquet>DADOS/PARQUET/ACESSOS/SYSTUR</caminho_parquet>
            <colunas>
                <usuario>USUARIO</usuario>
                <nome>NOME</nome>
                <perfil>PERFIL</perfil>
                <situacao>SITUACAO</situacao>
                <data_criacao>DATA_CRIACAO</data_criacao>
                <ultimo_acesso>ULTIMO_ACESSO</ultimo_acesso>
            </colunas>
        </sistema>

        <sistema id="IC">
            <nome>IC_INTEGRADOR_CONTABIL</nome>
            <descricao>Integrador Contábil</descricao>
            <caminho_entrada>ENTRADA/SISTEMAS/IC</caminho_entrada>
            <caminho_parquet>DADOS/PARQUET/ACESSOS/IC</caminho_parquet>
            <colunas>
                <usuario>USUARIO</usuario>
                <nome>NOME</nome>
                <perfil>PERFIL</perfil>
                <situacao>SITUACAO</situacao>
                <data_criacao>DATA_CRIACAO</data_criacao>
                <ultimo_acesso>ULTIMO_ACESSO</ultimo_acesso>
            </colunas>
        </sistema>
    </sistemas>

    <matrizes>
        <organizacional>
            <caminho>ENTRADA/MATRIZES/ORGANIZACIONAL</caminho>
            <colunas>
                <cargo_codigo>CARGO_CODIGO</cargo_codigo>
                <cargo_descricao>CARGO_DESCRICAO</cargo_descricao>
                <departamento>DEPARTAMENTO</departamento>
                <centro_custo>CENTRO_CUSTO</centro_custo>
            </colunas>
        </organizacional>
        <perfis_sistemas>
            <caminho>ENTRADA/MATRIZES/PERFIS_SISTEMAS</caminho>
            <colunas>
                <cargo_codigo>CARGO_CODIGO</cargo_codigo>
                <sistema>SISTEMA</sistema>
                <perfil>PERFIL</perfil>
            </colunas>
        </perfis_sistemas>
    </matrizes>

    <processamento>
        <encoding_padrao>utf-8</encoding_padrao>
        <separador_csv>;</separador_csv>
        <formato_data>%d/%m/%Y</formato_data>
        <mover_processados>true</mover_processados>
        <gerar_parquet>true</gerar_parquet>
        <gerar_relatorio>true</gerar_relatorio>
    </processamento>

    <saidas>
        <divergencias>DADOS/SAIDAS/DIVERGENCIAS</divergencias>
        <desligados>DADOS/SAIDAS/DESLIGADOS</desligados>
        <transferidos>DADOS/SAIDAS/TRANSFERIDOS</transferidos>
        <auditoria>DADOS/SAIDAS/AUDITORIA</auditoria>
        <logs>DADOS/LOGS</logs>
    </saidas>

    <!-- Caminhos locais do Visualizador — a preencher quando o exe for implementado -->
    <local>
        <parquet_destino></parquet_destino>
        <power_bi></power_bi>
    </local>
</configuracao>
